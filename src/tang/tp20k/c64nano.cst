IO_PORT "ws2812" IO_TYPE=LVCMOS33 PULL_MODE=DOWN DRIVE=8 BANK_VCCIO=3.3;

// LED 0 = DONE
// LED 1 = READY
IO_LOC "leds_n[5]" L16;
